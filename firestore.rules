rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config document (password, cutoff date) — read-only from client
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Doctors collection — read-only from client
    match /doctors/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Holidays collection — read-only from client (seeded via seed script)
    match /holidays/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Vacation requests — anyone can read (for heatmap), anyone can write (portal submissions)
    match /vacations/{vacId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['doctor', 'date', 'status', 'createdAt'])
                    && request.resource.data.keys().hasAll(['doctor', 'date', 'status'])
                    && request.resource.data.doctor is string
                    && request.resource.data.doctor.size() > 0
                    && request.resource.data.doctor.size() < 50
                    && request.resource.data.date is string
                    && request.resource.data.date.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}')
                    && request.resource.data.status in ['Pending', 'Approved', 'submitted'];
      allow delete: if true;
      allow update: if false;
    }
  }
}
